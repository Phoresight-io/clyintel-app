NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<publishable-key>
# Service-role key — server-only, required for audit_log and privileged writes;
# never expose client-side. Get it from Supabase → Project Settings → API.
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
Anthrop_API_Key=sk-ant-<your-key>
